{
  "entities": {
    "Curriculum": {
      "title": "Curriculum",
      "description": "A course curriculum generated by AI.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The UID of the user who created the curriculum." },
        "topic": { "type": "string", "description": "The course topic." },
        "audience": { "type": "string", "description": "The target audience." },
        "duration": { "type": "string", "description": "The course duration." },
        "goals": { "type": "string", "description": "The course goals." },
        "learningOutcomes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "level": { "type": "string" },
              "outcome": { "type": "string" }
            }
          }
        },
        "modules": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "lessons": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "title": { "type": "string" },
                    "description": { "type": "string" },
                    "duration": { "type": "string" }
                  }
                }
              },
              "assignment": { "type": "string" }
            }
          }
        },
        "syllabus": { "type": "string", "description": "Markdown formatted syllabus summary." },
        "createdAt": { "type": "number", "description": "Timestamp of creation." }
      },
      "required": ["userId", "topic", "audience", "duration", "goals", "learningOutcomes", "modules", "syllabus", "createdAt"]
    }
  },
  "firestore": {
    "/curricula/{curriculumId}": {
      "schema": "Curriculum",
      "description": "Collection of course curricula."
    }
  }
}
